{
  "domains": [],

  "subscribe": {
    "enable": true,
    "test": true,
    "exclude": false,

    "sources": [
      {
        "name": "github",
        "enable": true,
        "policy": "search",
        "keywords": ["clash", "v2ray", "sub"],
        "pages": 3
      },
      {
        "name": "telegram",
        "enable": true,
        "policy": "tgchannel",
        "channels": ["freevpn", "freeclash", "v2raydaily"]
      },
      {
        "name": "web",
        "enable": true,
        "policy": "search",
        "keywords": ["免费节点", "clash订阅", "v2ray订阅"],
        "pages": 2
      },
      {
        "name": "gist",
        "enable": true,
        "id": "d51852d8b18582ce5abe0686d6e11262"
      }
    ]
  },

  "filter": {
    "countries": ["HK", "MO", "TW", "JP", "SG", "US", "KR"],
    "exclude": ["校园", "公益", "限速", "回国", "中国", "Netease"],
    "allow": [],
    "max-latency": 400,
    "min-speed": 300,
    "max-count": 200,
    "unique": true,
    "remove-duplicated": true,
    "streaming": {
      "enable": true,
      "netflix": true,
      "youtube": true,
      "prime": false,
      "disney": true
    }
  },

  "test": {
    "enable": true,
    "timeout": 12,
    "concurrency": 12,
    "retry": 1,
    "sort": "speed",
    "latency-test_url": "http://www.gstatic.com/generate_204",
    "speed-test_url": "http://speed.cloudflare.com/__down"
  },

  "format": ["clash", "v2ray", "singbox"],

  "group": {
    "enable": true,
    "rules": [
      { "name": "HK", "keywords": ["香港", "HK"] },
      { "name": "JP", "keywords": ["日本", "JP"] },
      { "name": "SG", "keywords": ["新加坡", "SG"] },
      { "name": "US", "keywords": ["美国", "US"] },
      { "name": "Others", "keywords": [] }
    ]
  },

  "output": {
    "directory": "output",
    "clash": {
      "filename": "clash.yaml",
      "template": "subscribe/templates/clash.yaml"
    },
    "v2ray": {
      "filename": "v2ray.txt"
    },
    "singbox": {
      "filename": "singbox.json",
      "template": "subscribe/templates/singbox.json"
    }
  },

  "push": [
    {
    "type": "gist",
    "enable": true,
    "id": "d51852d8b18582ce5abe0686d6e11262",
    "token": "env:PUSH_TOKEN",
    "filename": "clash.yaml",
    "description": "Aggregator merged subscription", 
    "public": true
    }
  ]
}
